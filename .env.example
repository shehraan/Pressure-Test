# Vapi voice integration - get these from https://dashboard.vapi.ai
VITE_VAPI_PUBLIC_KEY=
VITE_VAPI_ASSISTANT_ID=
VITE_VAPI_ENABLED=true

# Convex backend - run `npx convex dev` to provision and auto-populate
VITE_CONVEX_URL=

# Optional PostHog analytics - leave blank to use the local stub logger
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
